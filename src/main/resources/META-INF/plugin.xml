<?xml version="1.0" encoding="UTF-8"?>
<idea-plugin>
     <id>com.github.iappapp.panda.common.generator</id>
     <name>Panda Code Generator</name>
     <version>1.2.0</version>
     <vendor email="iadore@live.cn" url="https://github.com/iappapp/panda-common-plugin">
          Panda Code Generator
     </vendor>

     <description><![CDATA[
          <b>Panda Code Generator for IntelliJ IDEA easy tools for developer</b><br/>
          <br/>
          一个强大的代码生成插件，支持：<br/>
          <ul>
               <li>从DDL SQL自动生成代码</li>
               <li>支持DO（数据对象）、Info（模型）、Model（DTO）生成</li>
               <li>支持Service、ServiceImpl、Mapper、Convert等代码</li>
               <li>灵活的Lombok和MyBatis-Plus开关配置</li>
               <li>一键快速代码生成</li>
          </ul>
     ]]></description>

     <change-notes><![CDATA[
          <b>Version 1.2.0</b><br/>
          <ul>
               <li>修复mapper生成错误问题</li>
          </ul>
     ]]></change-notes>

     <idea-version since-build="213"/>

     <depends>com.intellij.modules.platform</depends>
     <depends>com.intellij.modules.java</depends>

     <extensions defaultExtensionNs="com.intellij">
          <toolWindow id="Panda Code Generator"
                         anchor="right"
                         factoryClass="com.github.iappapp.panda.plugin.toolwindow.CodeGenToolWindowFactory"/>

          <projectService serviceImplementation="com.github.iappapp.panda.plugin.service.CodeGeneratorService"/>
     </extensions>

     <actions>
          <action id="PandaCodeGen.ShowToolWindow"
                    class="com.github.iappapp.panda.plugin.action.ShowToolWindowAction"
                    text="Panda Code Generator"
                    description="打开代码生成工具">
               <add-to-group group-id="ToolsMenu" anchor="last"/>
          </action>
     </actions>
</idea-plugin>